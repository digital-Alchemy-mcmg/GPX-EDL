{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gpx-edl.local/contracts/disk-definition.schema.json",
  "title": "Disk Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["disk_id", "version", "target", "sources", "limits"],
  "properties": {
    "disk_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["industry", "location", "radius_miles"],
      "properties": {
        "industry": {"type": "string", "minLength": 1},
        "location": {"type": "string", "minLength": 1},
        "radius_miles": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_active_listings"],
      "properties": {
        "max_active_listings": {"type": "integer", "minimum": 1}
      }
    }
  }
}
